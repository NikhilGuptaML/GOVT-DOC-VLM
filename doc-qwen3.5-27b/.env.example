# Hugging Face inference credentials
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Model and API routing
HF_BASE_URL=https://router.huggingface.co/v1
HF_MODEL_ID=Qwen/Qwen3.5-27B

# Inference controls
HF_MAX_TOKENS=4096
HF_TEMPERATURE=0.1
HF_TIMEOUT_SECONDS=180
HF_ENABLE_THINKING=true

# Runtime mode controls
# FORCE_MOCK=true always uses mock mode
# USE_MOCK=true also forces mock mode
FORCE_MOCK=false
USE_MOCK=false

# PDF conversion controls
PDF_DPI=200
MAX_IMAGE_WIDTH=2048

# Server
BACKEND_PORT=8001
